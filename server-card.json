{
  "name": "playwrightselectorguard",
  "title": "Playwright Selector Guard",
  "description": "Evaluate Playwright selectors, suggest healing candidates, require human approval for risky clicks, and archive action receipts.",
  "version": "1.0.0",
  "websiteUrl": "https://playwrightselectorguard.clauxel.com/",
  "documentationUrl": "https://playwrightselectorguard.clauxel.com/mcp/",
  "endpointUrl": "https://playwrightselectorguard.clauxel.com/mcp",
  "transport": "streamable-http",
  "authentication": {
    "type": "bearer",
    "required": true,
    "header": "Authorization",
    "format": "Bearer <paid-token>"
  },
  "paidAccess": {
    "required": true,
    "checkoutUrl": "https://playwrightselectorguard.clauxel.com/api/agent-checkout",
    "tokenStatusUrl": "https://playwrightselectorguard.clauxel.com/api/mcp-token/status",
    "tokenClaimUrl": "https://playwrightselectorguard.clauxel.com/api/mcp-token/claim",
    "defaultPlan": "team",
    "pricing": [
      {
        "id": "solo",
        "name": "Solo",
        "monthlyUsd": 39
      },
      {
        "id": "team",
        "name": "Team",
        "monthlyUsd": 129
      },
      {
        "id": "scale",
        "name": "Scale",
        "monthlyUsd": 349
      }
    ]
  },
  "tools": [
